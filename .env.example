# Database
DATABASE_URL=postgresql://user:password@localhost:5432/brushpro

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=your-audience-id
EMAIL_FROM=hello@opnrenovation.com
EMAIL_FROM_NAME=OPN Renovation

# Google Calendar OAuth (Scheduler)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourapp.com/api/v1/scheduler/google-callback

# reCAPTCHA v3 (website forms)
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Supabase Storage Buckets
STORAGE_BUCKET_RECEIPTS=receipts
STORAGE_BUCKET_INVOICES=invoices
STORAGE_BUCKET_CONTRACTS=contracts
STORAGE_BUCKET_BRANDING=branding
STORAGE_BUCKET_EMAIL_ASSETS=email-assets
STORAGE_BUCKET_SITE_ASSETS=site-assets

# App
JWT_SECRET=your-jwt-secret-min-32-chars-long-random-string
APP_URL=https://yourapp.com
SITE_URL=https://opnrenovation.com
CORS_ORIGIN=https://opnrenovation.com
PORT=3001
NODE_ENV=production
