{
  "name": "brushpro",
  "version": "1.5.0",
  "private": true,
  "workspaces": [
    "api",
    "shared",
    "web"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=api",
    "dev:web": "npm run dev --workspace=web",
    "build:api": "npm run build --workspace=api",
    "build:web": "npm run build --workspace=web",
    "db:generate": "npm run prisma:generate --workspace=api",
    "db:migrate": "npm run prisma:migrate --workspace=api",
    "db:deploy": "npm run prisma:deploy --workspace=api",
    "db:seed": "npm run prisma:seed --workspace=api",
    "db:studio": "npm run prisma:studio --workspace=api"
  }
}
